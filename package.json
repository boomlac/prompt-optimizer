{
  "name": "prompt-optimizer",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "build:extension-angular-scripts": "ng run prompt-optimizer:extension-build:production",
    "build:extension-scripts": "esbuild src-extension/background.ts --bundle --platform=browser --target=chrome120 --outfile=dist/extension/background.js && esbuild src-extension/content-script.ts --bundle --platform=browser --target=chrome120 --outfile=dist/extension/content-script.js",
    "build:extension": "npm run build:extension-angular-scripts && npm run build:extension-scripts",
    "build:all": "ng build && npm run build:extension",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "serve:ssr:prompt-optimizer": "node dist/prompt-optimizer/server/server.mjs",
    "firebase:login": "npx firebase-tools login",
    "firebase:use": "npx firebase-tools use --add",
   "firebase:deploy": "npm run build && npx firebase-tools deploy --only hosting"
  },
  "private": true,
  "packageManager": "npm@11.6.2",
  "dependencies": {
    "@angular/cdk": "^21.2.14",
    "@angular/common": "^21.2.0",
    "@angular/compiler": "^21.2.0",
    "@angular/core": "^21.2.0",
    "@angular/forms": "^21.2.0",
    "@angular/material": "^21.2.14",
    "@angular/platform-browser": "^21.2.0",
    "@angular/platform-server": "^21.2.0",
    "@angular/router": "^21.2.0",
    "@angular/ssr": "^21.2.2",
    "chart.js": "^4.5.1",
    "express": "^5.1.0",
    "firebase": "^12.15.0",
    "ng2-charts": "^4.1.1",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^21.2.2",
    "@angular/cli": "^21.2.2",
    "@angular/compiler-cli": "^21.2.0",
    "@types/chrome": "^0.2.2",
    "@types/express": "^5.0.1",
    "@types/node": "^20.17.19",
    "esbuild": "^0.28.1",
    "jsdom": "^28.0.0",
    "prettier": "^3.8.1",
    "typescript": "~5.9.2",
    "vitest": "^4.0.8"
  }
}