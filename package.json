{
  "name": "prompt-optimizer",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "build:ssr": "ng build",
    "build:vscode:angular": "ng run prompt-optimizer:vs-code-build:production",
    "build:vscode:scripts": "esbuild src-extension/background.ts --bundle --platform=browser --target=chrome120 --outfile=vs-extension/dist/background.js && esbuild src-extension/content-script.ts --bundle --platform=browser --target=chrome120 --outfile=vs-extension/dist/content-script.js",
    "build:vscode": "npm run build:vscode:angular && npm run build:vscode:scripts",
    "build:chrome": "ng run prompt-optimizer:extension-build:production && node build-extension.js",
    "package:chrome": "npm run build:chrome && powershell -Command \"Remove-Item -ErrorAction SilentlyContinue prompt-optimizer-chrome.zip; Compress-Archive -Path extension-build\\* -DestinationPath prompt-optimizer-chrome.zip\"","build:vscode:extension": "tsc -p vs-extension/",
    "package:vscode": "npm run build:vscode && npm run build:vscode:extension && cd vs-extension && npx @vscode/vsce package --allow-missing-repository --allow-star-activation",
    "build:all": "npm run build:ssr && npm run build:vscode",
    "watch": "ng build --watch --configuration=development",
    "test": "ng test",
    "serve:ssr": "node dist/prompt-optimizer/server/server.mjs",
    "firebase:login": "npx firebase-tools login",
    "firebase:use": "npx firebase-tools use --add",
    "firebase:deploy": "npm run build:ssr && npx firebase-tools deploy --only hosting"
  },
  "private": true,
  "packageManager": "npm@11.6.2",
  "dependencies": {
    "@angular/cdk": "^21.2.14",
    "@angular/common": "^21.2.0",
    "@angular/compiler": "^21.2.0",
    "@angular/core": "^21.2.0",
    "@angular/forms": "^21.2.0",
    "@angular/material": "^21.2.14",
    "@angular/platform-browser": "^21.2.0",
    "@angular/platform-server": "^21.2.0",
    "@angular/router": "^21.2.0",
    "@angular/ssr": "^21.2.2",
    "chart.js": "^4.5.1",
    "express": "^5.1.0",
    "firebase": "^12.15.0",
    "ng2-charts": "^4.1.1",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "vscode-webview": "^1.0.1-beta.1"
  },
  "devDependencies": {
    "@angular/build": "^21.2.2",
    "@angular/cli": "^21.2.2",
    "@angular/compiler-cli": "^21.2.0",
    "@types/chrome": "^0.2.2",
    "@types/express": "^5.0.1",
    "@types/node": "^20.17.19",
    "@types/vscode": "^1.125.0",
    "@vscode/vsce": "^3.9.2",
    "esbuild": "^0.28.1",
    "fs-extra": "^11.3.6",
    "jsdom": "^28.0.0",
    "prettier": "^3.8.1",
    "typescript": "~5.9.2",
    "vitest": "^4.0.8"
  }
}
